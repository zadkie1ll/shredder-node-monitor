NODE_MONITOR_LOG_LEVEL=info
NODE_MONITOR_INTERVAL_SECONDS=3600
NODE_MONITOR_RUN_ON_START=true
NODE_MONITOR_NODES_CONFIG=nodes.yaml

# Telegram. Можно переиспользовать токен shredder-vpn-bot через MI_VPN_BOT_TOKEN.
MI_VPN_BOT_TOKEN=
NODE_MONITOR_TELEGRAM_CHAT_ID=
# NODE_MONITOR_TELEGRAM_CHAT_IDS=123,456

# Remnawave panel API. Endpoint можно поменять под фактическую версию панели.
PANEL_URL=https://panel.example.com
RW_BEARER=
NODE_MONITOR_REMNAWAVE_NODES_ENDPOINT=/api/nodes
